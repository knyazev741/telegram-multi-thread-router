# === Proxy config (on server) ===
BOT_TOKEN=123456789:AAHfiqksKZ8...
OWNER_USER_ID=123456789
IPC_PORT=9600
AUTH_TOKEN=your-secret-token-here
PUBLIC_HOST=your.server.ip
PLUGIN_NAME=telegram-multi@telegram-multi-thread

# === Plugin config (on each machine running Claude Code) ===
# Set these in ~/.claude/channels/telegram-multi/.env
# TELEGRAM_THREAD_ID is set per-session via env var
#
# TELEGRAM_PROXY_HOST=your.server.ip
# TELEGRAM_PROXY_PORT=9600
# TELEGRAM_AUTH_TOKEN=your-secret-token-here
